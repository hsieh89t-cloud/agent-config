#!/usr/bin/env bash
set -euo pipefail

# Scan staged files only
files=$(git diff --cached --name-only --diff-filter=ACMR)
[ -z "$files" ] && exit 0

fail=0
patterns=(
  'BEGIN (RSA|OPENSSH|EC|DSA) PRIVATE KEY'
  'ghp_[A-Za-z0-9]{20,}'
  'github_pat_[A-Za-z0-9_]{20,}'
  'xox[baprs]-[A-Za-z0-9-]+'
  'AIza[0-9A-Za-z\-_]{35}'
  'sk-[A-Za-z0-9]{20,}'
)

while IFS= read -r f; do
  [ -f "$f" ] || continue
  # Skip obvious binary files
  if file "$f" | grep -qi 'binary'; then
    continue
  fi
  for p in "${patterns[@]}"; do
    if grep -nE "$p" "$f" >/dev/null 2>&1; then
      echo "[pre-commit] potential secret in $f (pattern: $p)"
      fail=1
    fi
  done
done <<< "$files"

if [ "$fail" -ne 0 ]; then
  echo "[pre-commit] commit blocked: remove secret-like content first."
  exit 1
fi

exit 0
